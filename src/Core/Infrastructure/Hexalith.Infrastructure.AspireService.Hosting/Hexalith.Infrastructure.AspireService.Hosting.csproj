<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Library</OutputType>
		<TargetFramework>net8.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IsAspireSharedProject>true</IsAspireSharedProject>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Aspire.Hosting" Version="$(AspireVersion)" />
		<PackageReference Include="Aspire.Hosting.Dapr" Version="$(AspireVersion)" />
		<PackageReference Include="Aspire.Hosting.Azure" Version="$(AspireVersion)" />
		<PackageReference Include="Aspire.Azure.Security.KeyVault" Version="$(AspireVersion)" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Helpers\" />
	</ItemGroup>
</Project>
